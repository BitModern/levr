{
  "name": "@levr-one/setup",
  "version": "1.0.0",
  "description": "Levr setup CLI — authenticate and list your Levr workspaces",
  "type": "module",
  "license": "MIT",
  "main": "./dist/cli.js",
  "bin": {
    "__levr_bash_complete": "./dist/bash-complete.js",
    "levr": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rimraf dist",
    "typecheck": "tsgo --noEmit",
    "lint:ts": "eslint src/**/*.ts --no-warn-ignored",
    "lint:format": "prettier --check \"src/**/*.ts\"",
    "lint": "npm-run-all --parallel \"lint:*\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "yarn build"
  },
  "keywords": [
    "cli",
    "levr",
    "auth",
    "oauth",
    "workspaces"
  ],
  "dependencies": {
    "@stricli/auto-complete": "^1.2.0",
    "@stricli/core": "^1.2.0",
    "@levr-one/auth": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.0.0",
    "@typescript/tsgo": "npm:@typescript/native-preview@^7.0.0-dev.20260113.1",
    "eslint": "^9.18.0",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsdown": "^0.15.6",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.0-beta.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BitModern/levr.git",
    "directory": "packages/setup"
  },
  "bugs": {
    "url": "https://github.com/BitModern/levr/issues"
  },
  "homepage": "https://github.com/BitModern/levr/tree/main/packages/setup#readme"
}
