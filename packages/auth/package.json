{
  "name": "@levr-one/auth",
  "version": "1.0.1",
  "description": "Shared OAuth 2.1 client with self-healing token management for TQ MCP servers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsgo --noEmit",
    "lint:ts": "eslint src/**/*.ts --no-warn-ignored",
    "lint:format": "prettier --check \"src/**/*.ts\"",
    "lint": "npm-run-all --parallel \"lint:*\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "precommit": "tsc"
  },
  "dependencies": {
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.0.0",
    "@typescript/tsgo": "npm:@typescript/native-preview@^7.0.0-dev.20260113.1",
    "eslint": "^9.18.0",
    "globals": "^16.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.0-beta.2"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BitModern/levr.git",
    "directory": "packages/auth"
  },
  "bugs": {
    "url": "https://github.com/BitModern/levr/issues"
  },
  "homepage": "https://github.com/BitModern/levr/tree/main/packages/auth#readme"
}
