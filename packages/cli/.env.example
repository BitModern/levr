# Levr CLI Configuration
# Export these variables for local development, e.g.:
#   export $(grep -v '^#' .env | xargs)
# Or use direnv with an .envrc file.

# API base URL (default: https://api.levr.one)
LEVR_URL=http://localhost:8080

# Auth server URL (default: https://auth.levr.one)
LEVR_AUTH_URL=http://localhost:3021

# Team ID — required for push commands
# LEVR_TEAM_ID=

# Personal Access Token — for CI/headless use (bypasses interactive login)
# LEVR_TOKEN=

# Automation source name override
# LEVR_SOURCE=
